{
  "/api/example/users": {
    "__mock_config__": {
      "method": "GET",
      "delay": 0,
      "active_id": "default",
      "title": "사용자 목록 조회",
      "description": "마이페이지 상단 사용자 정보 영역",
      "domain": "user"
    },
    "__mock_responses__": [
      {
        "id": "default",
        "status": 200,
        "label": "정상",
        "body": {
          "users": [
            {"id": 1, "name": "홍길동"},
            {"id": 2, "name": "김철수"}
          ]
        }
      },
      {
        "id": "empty",
        "status": 200,
        "label": "빈 목록",
        "body": {"users": []}
      },
      {
        "id": "server_error",
        "status": 500,
        "label": "서버 오류",
        "body": {"error": "Internal Server Error"}
      }
    ]
  },
  "/api/example/items/{item_id}": {
    "__mock_config__": {
      "method": "GET",
      "delay": 0,
      "active_status": 200
    },
    "__mock_responses__": {
      "200": {
        "item": {
          "uuid": "00000000-0000-0000-0000-000000000000",
          "name": "예시 상품",
          "price": 10000
        }
      },
      "404": {
        "error": "Not Found"
      }
    }
  }
}
